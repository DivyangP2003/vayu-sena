# ============================================================
# VAYU SAINIK — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- AI (Gemini) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Air Quality Data ---
# Get from: https://explore.openaq.org/developers/keys (free)
OPENAQ_API_KEY=your_openaq_api_key_here

# --- Weather Data ---
# Get from: https://openweathermap.org/api (free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Maps (optional, for satellite/terrain view) ---
# Get from: https://console.cloud.google.com → Maps JavaScript API (free tier)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here

# --- CPCB / data.gov.in ---
# Get from: https://data.gov.in/user/register (free)
DATA_GOV_IN_API_KEY=your_data_gov_in_key_here
